# Database connection URL (e.g. Supabase PostgreSQL connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# API Keys for different supported LLM providers
FRIDAY_API_KEY=your_openrouter_api_key_here
FRIDAY_NVIDIA_API_KEY=your_nvidia_api_key_here
FRIDAY_MISTRAL_API_KEY=your_mistral_api_key_here

# Database Sync Password/Passphrase key
FRIDAY_DB_KEY=your_supabase_sync_key_here
