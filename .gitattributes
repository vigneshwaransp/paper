# Handle line endings automatically for files detected as text
# and leave all files matching other rules alone.
* text=auto

# Declare files that will always have LF line endings on checkout.
*.js text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
